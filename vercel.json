{
    "version":2,
    "builds":[
        {
            "src": "./index.js",
            "use": "@vercel/node"
        },
        {
            "index.js": {
              "includeFiles": "templates/**"
            }
        }
    ],
    "routes":[
        {
            "src": "/(.*)",
            "dest": "/index.js"
        }
    ]
}